---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Header />

<main class="privacy-page">
    <div class="content">
        <h1>Privacy Policy</h1>

        <p>
            This website, <strong>The Game Changers Circuit</strong>, may use third-party advertising services and analytics tools, which may use cookies to display ads and analyze user activity based on visits to this and other websites.
        </p>

        <p>
            Cookies are small data files stored on your device that help improve your browsing experience, personalize content, and measure website performance.
        </p>

        <p>
            This website may collect basic, non-personal data to better understand how users interact with the content and to improve the overall experience.
        </p>

        <p>
            No personal information is sold or shared with third parties, except when required by law or when necessary to provide essential services of the website.
        </p>

        <p>
            By using this website, you consent to the use of cookies and the data practices described in this policy.
        </p>

        <p>
            If you have any questions, you can contact us at:
        </p>

        <p class="email">
            gamechangerscircuit@gmail.com
        </p>
    </div>
</main>

<Footer />

<style>
.privacy-page {
    background-color: #0b0f19;
    min-height: 100vh;
}

.content {
    max-width: 800px;
    margin: auto;
    padding: 2rem;

    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Ubuntu, sans-serif;
	color: #cbd5e1;
    font-size: 1.05rem;
    line-height: 1.7;
}

.content h1 {
    font-size: 4.5rem;
	line-height: 1.50;
	margin: 0;
	font-weight: 700;
	letter-spacing: -0.04em;


	background: linear-gradient(
		90deg,
		#ffffff 0%,
		#FA037F 100%
	);

	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;

	color: transparent;
}


.email {
    margin-top: 1rem;
    color: #f472b6;
    font-size: 1.1rem;
}
</style>

