---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const {
    title,
    description,
    pubDate,
    updatedDate,
    heroImage,
    author,
    background = '#0b0f19',
    showDate = true
} = Astro.props;

const resolvedHeroImage =
  typeof heroImage === 'string'
    ? heroImage
    : heroImage?.src;
---

<html lang="en">
    <head>
        <BaseHead
            title={title}
            description={description}
            image={resolvedHeroImage}
        />

        <style>
            main {
                width: calc(100% - 2em);
                background-color: #0b0f19;
                max-width: 100%;
                margin: 0;
            }

            .hero-image {
                width: 100%;
                background-color: #0b0f19;
            }

            .hero-image img {
                display: block;
                margin: 0 auto;
                border-radius: 12px;
                box-shadow: var(--box-shadow);
                max-width: 100%;
            }

            .prose {
                width: 1020px;
                max-width: calc(100% - 2em);
                margin: auto;
                padding: 1em;
                color: #cbd5e1;
            }

            .title {
                margin-bottom: 1em;
                padding: 1em 0;
                text-align: center;
                line-height: 1;
            }

            .post-title {
                margin: 0 0 0.5em 0;
                color: var(--pink);
            }

            .about-title {
                margin: 0 0 0.5em 0;

                background: linear-gradient(
                    90deg,
                    #ffffff 20%,
                    var(--pink-strong) 100%
                );

                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;

                color: transparent;
            }

            .date {
                margin-bottom: 0.5em;
                color: #f472b6;
                opacity: 0.9;
            }

            .author {
                margin-top: 1rem;
                font-size: 0.5rem;
                font-weight: 700;
                letter-spacing: 0.02em;
                color: #f472b6;
                text-transform: uppercase;
            }

            .last-updated-on {
                font-style: italic;
            }

            .prose :global(h2) {
                color: #f472b6;
                margin-top: 2.2rem;
                text-align: center;
                padding-bottom: 0.4rem;
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            }
        </style>
    </head>

    <body style={`background-color: ${background}`}>
        <Header />

        <main>
            <article>
                <div class="hero-image">
                    {resolvedHeroImage && (
                        <img
                            src={resolvedHeroImage}
                            alt=""
                            class="hero-img"
                        />
                    )}
                </div>

                <div class="prose">
                    <div class="title">
                        <div class="date">
                            <FormattedDate date={pubDate} />

                            {
                                updatedDate && (
                                    <div class="last-updated-on">
                                        Last updated on <FormattedDate date={updatedDate} />
                                    </div>
                                )
                            }
                        </div>

                        <h1 class={title === 'About Us' ? 'about-title' : 'post-title'}>
                            {title}
                        </h1>

                        {author && (
                            <div class="author">
                                By {author}
                            </div>
                        )}

                        <hr />
                    </div>

                    <slot />
                </div>
            </article>
        </main>

        <Footer />
    </body>
</html>