---
import PageLayout from '../layouts/PageLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<PageLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>

	<!-- HERO -->
	<section class="hero">				
		<p class="subtitle">
			Competitive coverage, analysis and stories from across the VALORANT Game Changers scene.
		</p>

		<div class="tags">
			<span>Circuit Watch</span>
			<span>Analysis</span>
			<span>Rosters</span>
			<span>Match Coverage</span>
		</div>
	</section>

	<!-- INTRO -->
	<section class="intro-block">
		<p class="intro">
			Coverage and analysis from across the VALORANT Game Changers circuit,
			focused on competitive results, roster movements and the evolution of
			the scene.
		</p>

		<p>
			Starting with GC EMEA — standings, playoffs, and the teams shaping one
			of the most competitive regions — with future coverage expanding into
			international events and the global GC ecosystem.
		</p>
	</section>
</PageLayout>

<style>

/* HERO */

.hero {
	  margin-top: 2.5rem;
	  
}

.tag {
	display: inline-block;
	font-size: 0.75rem;
	font-weight: 700;
	letter-spacing: 0.08em;
	text-transform: uppercase;
	color: #ff4fd8;
	text-shadow: 0 0 6px rgba(250, 3, 127, 0.4);
	margin-bottom: 1rem;
}

.subtitle {
	margin-top: 1rem;
	max-width: 700px;
	font-size: 1.15rem;
	line-height: 1.8;
	color: #ff4fd8;
}

/* TAGS */

.tags {
	display: flex;
	flex-wrap: wrap;
	gap: 1rem;
	margin-top: 2rem;
}

.tags span {
	background: rgba(255, 79, 216, 0.12);
	border: 1px solid rgba(255, 79, 216, 0.35);
	color: #ff4fd8;
	padding: 0.45rem 0.9rem;
	border-radius: 999px;
	font-size: 0.85rem;
	font-weight: 600;
}

/* INTRO */

.intro-block {
	margin-top: 3rem;
}

.intro {
	line-height: 1.8;
	color: #cbd5e1;
}

/* MOBILE */

@media (max-width: 768px) {
	h1 {
		font-size: 2.75rem;
	}

	.subtitle {
		font-size: 1rem;
	}
}

</style>
