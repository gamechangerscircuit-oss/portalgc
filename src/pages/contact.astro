---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Header />

<main class="page-container" style="background-color:#0b0f19; min-height:80vh;">
	<div class="content">
		<h1>Contact</h1>

		<p>For inquiries, collaborations or feedback, please reach out to:</p>

		<p class="email">
            gamechangerscircuit@gmail.com
        </p>
		</div>
</main>

<style>
	.page-container {
		background-color: #0b0f19;
		min-height: 100vh;
	}

	.content {
		max-width: 800px;
		margin: auto;
		padding: 2rem;
		font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Ubuntu, sans-serif;
		color: #cbd5e1;		
		font-size: 1.5rem		
	}
	.content h1 {
    font-size: 5rem;
	line-height: 1.15;
	margin: 0;
	font-weight: 700;
	letter-spacing: -0.04em;


	background: linear-gradient(
		90deg,
		#ffffff 0%,
		#FA037F 100%
	);

	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;

	color: transparent;
}
.email {
    margin-top: 1rem;
    color: #f472b6;
    font-size: 1.15rem;
</style>


<Footer />
